msgid "By subscribing to the RSS feed: https://www.ransomlook.io/rss.xml"
msgstr "En s'abonnant au flux RSS : https://www.ransomlook.io/rss.xml"

#: ../../index.rst:110 3c1e921c00bc4171a50e3c104f807fad
msgid ""
"By following us on Mastodon: `@Ransomlook@social.circl.lu "
"<https://social.circl.lu/@Ransomlook>`_"
msgstr ""
"En nous suivant sur Mastodon : `@Ransomlook@social.circl.lu "
